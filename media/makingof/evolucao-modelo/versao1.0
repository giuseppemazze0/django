Essa é a primeira versão do models.py

IA utilizada para verificar possíveis correções e melhoria no código, nomeadamente, ChatGPT.


>> ANTES DO USO DA IA <<


class Localizacao(models.Model):
    rua = models.CharField(max_length=100)
    bairro = models.CharField(max_length=100)
    cidade = models.CharField(max_length=100)


class Faculdade(models.Model):
    nome = models.CharField(max_length=100)
    max_capacidade_alunos = models.PositiveIntegerField()
    quantidade_salas = models.PositiveIntegerField()
    data_inauguracao = models.PositiveIntegerField()
    e_publica = models.BooleanField()
    localizacao = OneToOneField('Localizacao', on_delete=models.CASCADE)

    def __str__(self):
        self.nome


class Sala(models.Model):
    numero_sala = models.CharField(max_length=5)
    tem_computadores = models.BooleanField()
    numero_cadeiras = models.PositiveIntegerField()
    numero_mesas = models.PositiveIntegerField()


class Pessoa(models.Model):
    nome = models.CharField(max_length=100)
    email = models.EmailField(unique=True, blank=True, null=True)
    telefone = models.CharField(max_length=15, blank=True, null=True)

    class Meta:
        abstract = True

    def __str__(self):
        return self.nome


class Aluno(Pessoa):
    numero_aluno = models.CharField(max_length=10, unique=True)
    licenciatura = OneToOneField('Licenciatura', on_delete.CASCADE)
    competencia = ForeignKey('Competencia', on_delete=models.CASCADE, related_name='competencia_aluno')

class Professor(Pessoa):
    numero_professor = models.CharField(max_length=10, unique=True)
    leciona = ForeignKey('Licenciatura', on_delete.CASCADE, related_name='leciona_licenciatura')


class Semestre(models.Model):
    unidades_curriculares = ForeignKey('UnidadeCurricular', on_delete=models.CASCADE, 'semestre_unidade_curriculares')

    def __str__(self):
        self.nome


class UnidadeCurricular(models.Model):
    nome = models.CharField(max_length=100)
    ects = models.PositiveIntegerField()
    descricao = models.CharField(max_digits=500)
    preRequisitos = models.CharField(max_length=100, null=True)
    bibliografia = models.CharField(max_length=300)
    objetivos = models.CharField(max_length=300)
    imagem = models.ImageField(upload_to='unidade-curricular/')
    sala = OneToOneField('Sala', on_delete=models.CASCADE)
    projetos = ForeignKey('Projeto', on_delete=models.CASCADE, related_name='projetos_unidade_curricular')
    competencia_adquirida = ForeignKey('Competencia', on_delete=models.CASCADE, related_name='competencia_adquirida_unidade_curricular')

    def __str__(self):
        self.nome


class AnoCurricular(models.Model):
    ano = models.PositiveIntegerField()
    semestre1 = OneToOneField('Semestre', on_delete=models.CASCADE)
    semestre2 = OneToOneField('Semestre', on_delete=models.CASCADE)

    def __str__(self):
        self.ano


class Licenciatura(models.Model):
    nome = models.CharField(max_length=100)
    mestrado_integrado = models.BooleanField()
    ects = models.PositiveIntegerField()
    descricao = models.CharField(max_digits=500)
    obejetivo_curso = models.CharField(max_digits=500)
    total_anos = models.PositiveIntegerField()
    tem_bolsa = models.BooleanField()
    planos_estudo = ForeignKey('AnoCurricular', on_delete=models.CASCADE, related_name='plano_estudo_ano_curricular')
    competencias_adquiridas = models.CharField(max_length=500)
    destinatario = models.CharField(max_length=500)
    ligacao_meio_empresarial = models.CharField(max_length=500)
    oportunidade_carreira = models.CharField(max_length=500)
    faculdade = ForeignKey('Faculdade', on_delete=models.CASCADE, related_name='curso')
    tfc = OneToOneField('TFC', on_delete=models.CASCADE, related_name='tfc_licenciatura')
    formacao = OneToOneField('Formacao', on_delete=models.CASCADE, related_name='formacao_licenciatura')

    def __str__(self):
        self.nome


class Projeto(models.Model):
    nome = models.CharField(max_length=50)
    descricao = models.CharField(max_length=500)
    nota = models.PositiveIntegerField(max_digits=20)
    prazo = models.DateTimeField()
    tecnologia_usada = ForeignKey('Tecnologia', on_delete=models.CASCADE, related_name='tecnologia_projeto')
    conceito_unidade_curricular = models.CharField(max_length=500)
    link_github = models.CharField(max_length=200)
    link_video_youtube = models.CharField(max_length=200)
    imagem = models.ImageField(upload_to='projeto/')


class Tecnologia(models.Model):
    nome = models.CharField(max_length=50)
    logo = models.ImageField(upload_to='logo-tecnologia/')
    link_website_oficial = models.CharField(max_length=200)
    nivel_interesse = models.PositiveIntegerField(max_digits=5)
    nivel_dificuldade = models.PositiveIntegerField(max_digits=5)


class TFC(models.Model):
    nome = models.CharField(max_length=100)
    descricao = models.CharField(max_length=500)
    nota = models.PositiveIntegerField(max_digits=20)


class Competencia(models.Model):
    habilidade = models.CharField(max_length=100)
    soft_skill = models.CharField(max_length=100)
    hard_skill = models.CharField(max_length=100)
    hobby = models.CharField(max_length=100)


class Formacao(models.Model):
    nome = models.CharField(max_length=100)
    data_inicio = models.DateField()
    data_fim = models.DateField()
    certificado = models.ImageField(upload_to='certificado/')


